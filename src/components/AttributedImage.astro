---
import type { ImageAttribution } from '../lib/content-data';

interface Props {
  src: string;
  alt: string;
  attribution?: ImageAttribution;
  href?: string;
  loading?: 'lazy' | 'eager';
  imageStyle?: string;
  wrapperStyle?: string;
  compact?: boolean;
}

const {
  src,
  alt,
  attribution,
  href,
  loading = 'lazy',
  imageStyle,
  wrapperStyle,
  compact = false,
} = Astro.props;

const imageHref = href;
const opensExternal = Boolean(imageHref && /^https?:\/\//.test(imageHref));
---

<div class:list={['attributed-image', compact && 'attributed-image-compact']} style={wrapperStyle}>
  {imageHref ? (
    <a href={imageHref} target={opensExternal ? '_blank' : undefined} rel={opensExternal ? 'noreferrer' : undefined}>
      <img src={src} alt={alt} loading={loading} style={imageStyle} />
    </a>
  ) : (
    <img src={src} alt={alt} loading={loading} style={imageStyle} />
  )}
  {attribution && (
    <a
      class="attribution-badge"
      href={attribution.sourceUrl}
      target="_blank"
      rel="noreferrer"
      aria-label={attribution.sourceLabel}
      title={attribution.sourceLabel}
    >
      <span>{compact ? 'Source' : attribution.sourceLabel}</span>
    </a>
  )}
</div>

<style>
  .attributed-image {
    position: relative;
  }

  .attributed-image a,
  .attributed-image img {
    display: block;
  }

  .attributed-image img {
    width: 100%;
  }

  .attribution-badge {
    position: absolute;
    right: 0.85rem;
    bottom: 0.85rem;
    max-width: min(72%, 26rem);
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.84);
    color: white;
    font-size: 0.74rem;
    line-height: 1.2;
    text-decoration: none;
    backdrop-filter: blur(8px);
  }

  .attribution-badge:hover {
    color: white;
    background: rgba(15, 23, 42, 0.94);
  }

  .attributed-image-compact .attribution-badge {
    right: 0.65rem;
    bottom: 0.65rem;
    max-width: 70%;
    padding: 0.32rem 0.55rem;
    font-size: 0.68rem;
  }
</style>
