---
interface Props {
  eyebrow?: string;
  title: string;
  intro: string;
  actionHref?: string;
  actionLabel?: string;
}
const { eyebrow, title, intro, actionHref, actionLabel } = Astro.props;
---

<div class="stack" style="margin-bottom: 2.5rem; max-width: 720px;">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h1 style="margin: 1.25rem 0 1.5rem; font-size: clamp(2.4rem, 5vw, 4.8rem); line-height: 0.96; letter-spacing: -0.06em;">{title}</h1>
  <p class="muted" style="font-size: 1.1rem; margin: 0;">{intro}</p>
  {actionHref && actionLabel && (
    <div>
      <a class="button" href={actionHref}>{actionLabel}</a>
    </div>
  )}
</div>
