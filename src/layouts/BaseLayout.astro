---
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import { navByLocale, site, type Locale } from '../lib/site';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  alternatePath?: string;
}

const { locale, title, description, image = site.socialImage, imageAlt = title, alternatePath } = Astro.props;
const nav = navByLocale[locale];
const currentUrl = new URL(Astro.url.pathname, Astro.site ?? site.baseUrl).toString();
const alternateUrl = alternatePath ? new URL(alternatePath, Astro.site ?? site.baseUrl).toString() : null;
const currentPath = Astro.url.pathname;
const requestedImage = image || site.socialImage;
const socialImagePath = requestedImage.toLowerCase().endsWith('.svg') ? site.socialImage : requestedImage;
const socialImageUrl = new URL(socialImagePath, Astro.site ?? site.baseUrl).toString();
const socialLocale = locale === 'it' ? 'it_IT' : 'en_GB';
const alternateSocialLocale = locale === 'it' ? 'en_GB' : 'it_IT';
const themeToggleTitle = locale === 'it' ? 'Cambia tema' : 'Toggle theme';
const lightThemeLabel = locale === 'it' ? 'Chiaro' : 'Light';
const darkThemeLabel = locale === 'it' ? 'Scuro' : 'Dark';
const themeSystemHint = locale === 'it' ? 'Segue il tema del sistema finché non lo cambi.' : 'Follows the system theme until you change it.';
const shortPrivacyNotice =
  locale === 'it'
    ? 'Questo sito non imposta cookie di profilazione o analytics. Salva solo la preferenza del tema nel browser per migliorare la lettura.'
    : 'This site does not set profiling or analytics cookies. It only stores your theme preference in the browser to improve readability.';

const footerAffiliations = locale === 'it'
  ? [
      { label: site.contactRole.it, href: site.addressUrl },
      { label: "Director of the Brescia's Node of the CINI National Cybersecurity Lab", href: 'https://cyberseclab.unibs.it/' },
      { label: 'Visiting Senior Lecturer, Cardiff University' },
      { label: 'Visiting Fellow, University of Southampton' },
      { label: 'Visiting Professor, Imperial College London' },
    ]
  : [
      { label: site.contactRole.en, href: site.addressUrl },
      { label: "Director of the Brescia's Node of the CINI National Cybersecurity Lab", href: 'https://cyberseclab.unibs.it/' },
      { label: 'Visiting Senior Lecturer, Cardiff University' },
      { label: 'Visiting Fellow, University of Southampton' },
      { label: 'Visiting Professor, Imperial College London' },
    ];

function isExternalUrl(href: string) {
  return href.startsWith('http://') || href.startsWith('https://');
}

function isActivePath(href: string) {
  if (isExternalUrl(href)) return false;
  return currentPath === href || currentPath.startsWith(href);
}
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={currentUrl} />
    {alternateUrl && <link rel="alternate" hreflang={locale === 'it' ? 'en' : 'it'} href={alternateUrl} />}
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={socialLocale} />
    <meta property="og:locale:alternate" content={alternateSocialLocale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored === 'light' || stored === 'dark' ? stored : (systemDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #ffffff;
        --surface: #ffffff;
        --text: #111111;
        --muted: #666666;
        --line: #e9e9e9;
        --line-strong: #d9d9d9;
        --accent: #111111;
        --header-bg: rgba(255,255,255,0.94);
        --theme-button-bg: transparent;
        --theme-button-border: var(--line);
        --control-bg: #ffffff;
        --control-text: var(--text);
        --control-placeholder: #8a8a8a;
        --tag-bg: transparent;
        --tag-border: var(--line-strong);
        --portrait-filter: none;
        --container: 1120px;
        --radius: 0px;
      }
      :root[data-theme='dark'] {
        color-scheme: dark;
        --bg: #101214;
        --surface: #16191d;
        --text: #f3f5f7;
        --muted: #a7b0b8;
        --line: #2a3138;
        --line-strong: #3a434b;
        --accent: #f3f5f7;
        --header-bg: rgba(16,18,20,0.92);
        --theme-button-bg: #16191d;
        --theme-button-border: #3a434b;
        --control-bg: #181c20;
        --control-text: #f3f5f7;
        --control-placeholder: #8f99a2;
        --tag-bg: #1b2025;
        --tag-border: #4a535c;
        --portrait-filter: brightness(0.82) contrast(1.08) saturate(0.9);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 300;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }
      main { min-height: 60vh; }
      .container { width: min(var(--container), calc(100% - 2.5rem)); margin: 0 auto; }
      .surface { background: transparent; }
      .eyebrow {
        display: inline-block;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .grid { display: grid; gap: 1.5rem; }
      .card {
        background: transparent;
        border: 0;
        padding-top: 1.1rem;
      }
      .button, button, select, input { font: inherit; }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.8rem 0;
        border: 0;
        background: transparent;
        color: var(--text);
        font-weight: 500;
      }
      .button.secondary { color: var(--muted); }
      .button.disabled { color: var(--muted); cursor: not-allowed; }
      .section { padding: 4.5rem 0; }
      .stack > * + * { margin-top: 1rem; }
      .muted { color: var(--muted); }
      .meta { display: flex; flex-wrap: wrap; gap: 0.75rem; color: var(--muted); font-size: 0.92rem; }
      .tag {
        display: inline-flex;
        padding: 0.18rem 0.45rem;
        border: 1px solid var(--tag-border);
        background: var(--tag-bg);
        color: var(--muted);
        font-size: 0.84rem;
      }
      .prose { font-size: 1.03rem; max-width: 68ch; }
      .prose h2, .prose h3 { line-height: 1.2; margin-top: 2rem; }
      .prose p { color: var(--text); }
      .prose ul { padding-left: 1.2rem; }
      header.site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: var(--header-bg);
        backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--line);
      }
      .site-header-inner {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        justify-content: flex-start;
        padding: 1rem 0;
      }
      .header-nav-wrap {
        display: flex;
        align-items: flex-start;
        gap: 2.75rem;
        flex: 1;
        min-width: 0;
      }
      .brand {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.1rem;
        min-width: 0;
      }
      .brand strong {
        display: block;
        font-size: 0.98rem;
        letter-spacing: -0.03em;
        font-weight: 400;
        line-height: 1.15;
      }
      .brand span {
        display: block;
        color: var(--text);
        font-size: 0.98rem;
        letter-spacing: -0.03em;
        font-weight: 400;
        line-height: 1.15;
      }
      nav.primary-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        justify-content: flex-start;
        margin-left: 2.25rem;
        margin-top: 0;
        align-self: flex-start;
      }
      nav.primary-nav a, .lang-switch {
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.15;
      }
      nav.primary-nav a:hover, .lang-switch:hover { color: var(--text); }
      nav.primary-nav a {
        position: relative;
        display: inline-flex;
        align-items: center;
        min-height: 2rem;
        padding: 0.2rem 0;
      }
      nav.primary-nav a[aria-current='page'] {
        color: var(--text);
      }
      nav.primary-nav a[aria-current='page']::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -0.18rem;
        height: 2px;
        background: currentColor;
      }
      .header-utilities {
        display: inline-flex;
        align-items: flex-start;
        gap: 0.65rem;
        margin-left: auto;
        padding-left: 1rem;
        padding-top: 0;
        border-left: 1px solid var(--line);
        align-self: flex-start;
      }
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        margin-top: 0;
        padding: 0;
        border: 1px solid var(--theme-button-border);
        background: var(--theme-button-bg);
        color: var(--muted);
        cursor: pointer;
        border-radius: 999px;
        flex: 0 0 auto;
      }
      .theme-toggle:hover { color: var(--text); border-color: var(--line-strong); }
      .theme-toggle svg { width: 0.82rem; height: 0.82rem; }
      .theme-toggle [data-theme-icon='light'],
      :root[data-theme='dark'] .theme-toggle [data-theme-icon='dark'] { display: none; }
      :root[data-theme='dark'] .theme-toggle [data-theme-icon='light'] { display: block; }
      .theme-toggle [data-theme-icon='dark'] { display: block; }
      .lang-switch {
        display: inline-flex;
        align-items: center;
        line-height: 1;
        font-size: 1.15rem;
        min-height: 2rem;
      }
      footer.site-footer {
        padding: 2.5rem 0 2rem;
        border-top: 1px solid var(--line);
      }
      .site-footer-main {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(220px, 0.4fr);
        gap: 2.5rem;
        align-items: start;
      }
      .footer-panel {
        display: grid;
        gap: 0.85rem;
      }
      .footer-affiliations {
        display: grid;
        gap: 0.35rem;
      }
      .footer-affiliation {
        margin: 0;
      }
      .footer-affiliation a {
        color: var(--muted);
      }
      .footer-affiliation a:hover {
        color: var(--text);
      }
      .footer-panel--nav {
        justify-self: end;
        width: 100%;
        max-width: 14rem;
      }
      .footer-brand {
        max-width: 34rem;
      }
      .footer-brand strong {
        display: block;
        font-size: clamp(1.15rem, 1rem + 0.5vw, 1.45rem);
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-top: 0.5rem;
      }
      .footer-brand p {
        margin: 0;
        color: var(--muted);
      }
      .footer-meta {
        display: grid;
        gap: 0.65rem;
        margin-top: 0;
        margin-bottom: 0.2rem;
      }
      .footer-meta a {
        width: fit-content;
      }
      .footer-cta {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding-bottom: 0.15rem;
        border-bottom: 1px solid var(--line-strong);
        color: var(--text);
        font-weight: 500;
      }
      .footer-list,
      .footer-nav {
        display: grid;
        gap: 0.65rem;
      }
      .footer-list a,
      .footer-nav a {
        color: var(--muted);
        width: fit-content;
      }
      .footer-list a:hover,
      .footer-nav a:hover {
        color: var(--text);
      }
      .footer-label {
        display: inline-block;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 0.9rem;
      }
      .footer-bottom {
        margin-top: 2rem;
        padding-top: 1rem;
        color: var(--muted);
        font-size: 0.92rem;
      }
      .footer-bottom p {
        margin: 0 0 0.5rem;
        max-width: 56rem;
      }
      h1, h2, h3, p, a, span {
        overflow-wrap: anywhere;
      }
      .hero-grid, .two-col {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 2.5rem;
        align-items: start;
      }
      .hero-panel { padding: 0; }
      .hero-image { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; }
      .portrait-image { filter: var(--portrait-filter); }
      .collection-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 2rem; }
      .people-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); column-gap: 3.25rem; row-gap: 4rem; }
      .detail-shell { display: grid; grid-template-columns: minmax(0, 0.72fr) minmax(220px, 0.28fr); gap: 2.5rem; }
      .sticky-side { position: sticky; top: 6rem; }
      .detail-article {
        min-width: 0;
      }
      .detail-title {
        margin: 0.35rem 0 0;
        font-size: clamp(2.4rem, 5vw, 4rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
      }
      .detail-hero-image {
        margin: 1.25rem 0;
        border-radius: 18px;
        max-height: 420px;
        width: 100%;
        object-fit: cover;
      }
      .detail-meta-links {
        margin-bottom: 1rem;
      }
      .detail-facts {
        display: grid;
        gap: 0.4rem;
        margin-top: 0.9rem;
      }
      .detail-facts p {
        margin: 0;
      }
      .filter-shell { display: grid; gap: 2rem; }
      .filter-controls {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 0.75rem;
        padding-bottom: 1rem;
      }
      .filter-controls input, .filter-controls select {
        width: 100%;
        background: var(--control-bg);
        border: 1px solid var(--line-strong);
        border-radius: 0;
        padding: 0.85rem 0.9rem;
        color: var(--control-text);
        appearance: none;
      }
      .filter-controls input::placeholder {
        color: var(--control-placeholder);
      }
      .filter-controls select {
        background-image:
          linear-gradient(45deg, transparent 50%, var(--muted) 50%),
          linear-gradient(135deg, var(--muted) 50%, transparent 50%);
        background-position:
          calc(100% - 18px) calc(50% - 3px),
          calc(100% - 12px) calc(50% - 3px);
        background-size: 6px 6px, 6px 6px;
        background-repeat: no-repeat;
      }
      .filter-list { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 2rem; }
      .filter-list-spacious { column-gap: 3.25rem; row-gap: 4rem; }
      .is-hidden { display: none !important; }
      @media (max-width: 960px) {
        .hero-grid, .two-col, .detail-shell, .site-footer-main, .filter-controls, .filter-list, .collection-grid, .people-grid { grid-template-columns: 1fr; }
        .sticky-side { position: static; }
        .section { padding: 3.25rem 0; }
        .site-header-inner {
          display: grid;
          grid-template-columns: minmax(0, 1fr) auto;
          gap: 0.85rem 0.9rem;
          align-items: start;
          padding: 0.85rem 0 1rem;
        }
        .brand {
          min-width: 0;
          grid-column: 1;
          grid-row: 1;
        }
        .header-nav-wrap {
          width: 100%;
          grid-column: 1 / -1;
          grid-row: 2;
          flex-direction: column;
          align-items: stretch;
          gap: 0.65rem;
        }
        nav.primary-nav {
          justify-content: flex-start;
          gap: 0.45rem 0.8rem;
          margin-left: 0;
          padding-top: 0;
        }
        nav.primary-nav a {
          min-height: 1.8rem;
          padding: 0.1rem 0;
        }
        .header-utilities {
          position: static;
          grid-column: 2;
          grid-row: 1;
          padding-left: 0;
          padding-top: 0;
          border-left: 0;
          border-top: 0;
          width: auto;
          justify-content: flex-end;
          align-items: center;
        }
        .footer-panel--nav {
          justify-self: start;
          max-width: none;
        }
        .meta {
          gap: 0.55rem;
        }
        .detail-shell {
          gap: 1.5rem;
        }
        .detail-title {
          font-size: clamp(2rem, 8.5vw, 3.1rem);
        }
        .detail-hero-image {
          margin: 1rem 0;
          border-radius: 12px;
        }
        .prose {
          font-size: 1rem;
        }
        .container { width: min(var(--container), calc(100% - 1.5rem)); }
      }
      @media (max-width: 720px) {
        .section {
          padding: 2.75rem 0;
        }
        .site-header-inner {
          gap: 0.7rem;
        }
        .brand strong,
        .brand span {
          font-size: 0.94rem;
          line-height: 1.1;
        }
        nav.primary-nav {
          gap: 0.35rem 0.75rem;
        }
        nav.primary-nav a,
        .lang-switch {
          font-size: 0.92rem;
        }
        .theme-toggle {
          width: 2.15rem;
          height: 2.15rem;
        }
        .detail-title {
          font-size: clamp(1.8rem, 10vw, 2.5rem);
          letter-spacing: -0.05em;
        }
        .detail-meta-links {
          margin-bottom: 0.75rem;
        }
        .footer-brand strong {
          font-size: 1.2rem;
        }
        .tag {
          font-size: 0.8rem;
        }
      }
      @media (min-width: 961px) and (max-width: 1180px) {
        .people-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); column-gap: 2.5rem; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href={locale === 'it' ? '/it/' : '/'}>
          <strong>Prof. Federico Cerutti</strong>
          <span>{locale === 'it' ? 'AI, cybersecurity e ragionamento sotto incertezza' : 'AI, cybersecurity, and reasoning under uncertainty'}</span>
        </a>
        <div class="header-nav-wrap">
          <nav class="primary-nav" aria-label="Primary">
          {nav.map((item) => <a href={item.href} target={isExternalUrl(item.href) ? '_blank' : undefined} rel={isExternalUrl(item.href) ? 'noreferrer' : undefined} aria-current={isActivePath(item.href) ? 'page' : undefined}>{item.label}</a>)}
        </nav>
        </div>
        <div class="header-utilities" aria-label={locale === 'it' ? 'Controlli interfaccia' : 'Interface controls'}>
          <button
            class="theme-toggle"
            type="button"
            data-theme-toggle
            data-light-label={lightThemeLabel}
            data-dark-label={darkThemeLabel}
            data-toggle-title={themeToggleTitle}
            data-system-hint={themeSystemHint}
            title={themeSystemHint}
            aria-label={themeToggleTitle}
          >
            <svg data-theme-icon="dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
            </svg>
            <svg data-theme-icon="light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2.2M12 19.8V22M4.22 4.22l1.56 1.56M18.22 18.22l1.56 1.56M2 12h2.2M19.8 12H22M4.22 19.78l1.56-1.56M18.22 5.78l1.56-1.56" />
            </svg>
          </button>
          <a class="lang-switch" href={alternatePath ?? (locale === 'it' ? '/' : '/it/')} aria-label={locale === 'it' ? 'Switch to English' : 'Passa a Italiano'}>
            {locale === 'it' ? 'EN' : 'IT'}
          </a>
        </div>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="container site-footer-main">
        <div class="footer-panel footer-brand stack">
          <strong>{site.name}</strong>
          <div class="footer-affiliations">
            {footerAffiliations.map((item) => (
              <p class="footer-affiliation">
                {item.href ? (
                  <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
                ) : (
                  item.label
                )}
              </p>
            ))}
          </div>
          <div class="footer-meta">
            <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
          </div>
        </div>
        <div class="footer-panel footer-panel--nav">
          <span class="footer-label">{locale === 'it' ? 'Esplora' : 'Explore'}</span>
          <nav class="footer-nav" aria-label={locale === 'it' ? 'Navigazione footer' : 'Footer navigation'}>
            {nav.map((item) => <a href={item.href} target={isExternalUrl(item.href) ? '_blank' : undefined} rel={isExternalUrl(item.href) ? 'noreferrer' : undefined}>{item.label}</a>)}
          </nav>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>{shortPrivacyNotice}</p>
        <span>
          {locale === 'it' ? (
            <a href="https://www.unibs.it/it/privacy-policy-university-portals" target="_blank" rel="noopener noreferrer">
              Privacy policy dell’Università degli Studi di Brescia
            </a>
          ) : (
            <a href="https://www.unibs.it/it/privacy-policy-university-portals" target="_blank" rel="noopener noreferrer">
              University of Brescia privacy policy
            </a>
          )}
        </span>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const button = document.querySelector('[data-theme-toggle]');
        const themeColor = document.querySelector('meta[name="theme-color"]');
        if (!button) return;

        const labels = {
          light: button.dataset.lightLabel || 'Light',
          dark: button.dataset.darkLabel || 'Dark',
        };
        const toggleTitle = button.dataset.toggleTitle || 'Toggle theme';
        const systemHint = button.dataset.systemHint || '';

        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          if (themeColor) {
            themeColor.setAttribute('content', theme === 'dark' ? '#101214' : '#ffffff');
          }
          button.setAttribute('title', `${toggleTitle}: ${labels[theme]}${systemHint ? `. ${systemHint}` : ''}`);
          button.setAttribute('aria-label', `${toggleTitle}: ${labels[theme]}`);
        };

        applyTheme(root.dataset.theme === 'dark' ? 'dark' : 'light');

        button.addEventListener('click', () => {
          const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
          localStorage.setItem('theme', next);
          applyTheme(next);
        });
      })();
    </script>
  </body>
</html>
