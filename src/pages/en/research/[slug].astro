---
import BaseLayout from '../../../layouts/BaseLayout.astro'; import AttributedImage from '../../../components/AttributedImage.astro'; import DetailSidebar from '../../../components/DetailSidebar.astro'; import { getLocalizedCollection, getTranslation } from '../../../lib/content-data'; import { formatDate } from '../../../lib/site';
export function getStaticPaths() { return getLocalizedCollection('papers', 'en').map((entry) => ({ params: { slug: entry.pathSlug }, props: { entry } })); }
const { entry } = Astro.props; const alt = getTranslation('papers', entry.translationKey, 'it');
---
<BaseLayout locale="en" title={entry.seo.title} description={entry.seo.description} image={entry.image} alternatePath={alt ? `/ricerca/${alt.pathSlug}/` : '/ricerca/'}><section class="section"><div class="container detail-shell"><article class="surface detail-article"><span class="eyebrow">{entry.typeLabel}</span><h1 class="detail-title">{entry.title}</h1><div class="detail-facts"><p class="muted"><strong>Published:</strong> {formatDate(new Date(entry.publishedAt), 'en')}</p><p class="muted"><strong>Authors:</strong> {entry.authors.join(', ')}</p><p class="muted"><a href={entry.officialUrl} target="_blank" rel="noreferrer">Read the publication</a></p></div>{entry.image && <AttributedImage src={entry.image} alt={entry.title} attribution={entry.imageAttribution} imageStyle="margin: 1.25rem 0; border-radius: 18px; max-height: 420px; width: 100%; object-fit: cover;" />}<div class="prose" set:html={entry.body} /></article><DetailSidebar title="References" items={entry.tags} /></div></section></BaseLayout>
