---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AttributedImage from '../../components/AttributedImage.astro';
import DetailSidebar from '../../components/DetailSidebar.astro';
import { getLocalizedCollection, getTranslation } from '../../lib/content-data';

export function getStaticPaths() {
  return getLocalizedCollection('projects', 'it').map((entry) => ({ params: { slug: entry.pathSlug }, props: { entry } }));
}

const { entry } = Astro.props;
const alt = getTranslation('projects', entry.translationKey, 'en');
---
<BaseLayout locale="it" title={entry.seo.title} description={entry.seo.description} image={entry.image} alternatePath={alt ? `/en/projects/${alt.pathSlug}/` : '/en/projects/'}>
  <section class="section">
    <div class="container detail-shell">
      <article class="surface detail-article">
        <span class="eyebrow">Progetto</span>
        <h1 class="detail-title">{entry.title}</h1>
        <div class="detail-facts">
          <p class="muted"><strong>Finanziatore:</strong> {entry.funder}</p>
          <p class="muted"><strong>Periodo:</strong> {entry.startDate} {entry.endDate ? `– ${entry.endDate}` : ''}</p>
          <p class="muted"><strong>Stato:</strong> {entry.status}</p>
        </div>
        {entry.image && (
          <AttributedImage
            src={entry.image}
            alt={entry.title}
            attribution={entry.imageAttribution}
            imageStyle="margin: 1.25rem 0; max-height: 420px; width: 100%; object-fit: cover;"
          />
        )}
        <div class="prose" set:html={entry.body} />
      </article>
      <DetailSidebar title="Riferimenti" items={entry.tags.concat(entry.people)} />
    </div>
  </section>
</BaseLayout>
