---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { getTeachingSections } from '../../lib/content-data';

const sections = getTeachingSections('it');
---
<BaseLayout locale="it" title="Didattica | Federico Cerutti" description="Insegnamenti, tutorial di ricerca, corsi di dottorato e temi di tesi." image="/images/people/federico-cerutti.png" alternatePath="/en/teaching/">
  <section class="section">
    <div class="container">
      <SectionIntro title="Didattica" />
    </div>
  </section>
  {sections.map((section) => (
    <section class="section">
      <div class="container stack">
        <div class="section-block">
          <span class="eyebrow">{section.title}</span>
          <p class="muted">{section.intro}</p>
        </div>
        <div class="collection-grid">
          {section.items.map((item) => (
            <article class="surface card stack">
              <div class="meta">{item.when && <span>{item.when}</span>}</div>
              <h3>{item.href ? <a href={item.href}>{item.title}</a> : item.title}</h3>
              <p class="muted">{item.summary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <style>
    .section-block p,
    .section-block h2,
    .collection-grid h3,
    .collection-grid p {
      margin: 0;
    }

    .collection-grid h3 {
      font-size: 1.25rem;
      line-height: 1.02;
      letter-spacing: -0.04em;
    }
  </style>
</BaseLayout>
